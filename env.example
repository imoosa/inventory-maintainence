# =============================================
# House Inventory System — Environment Config
# Copy this to .env and fill in your values
# =============================================

# App
SECRET_KEY=change-this-to-a-random-secret-key
DATABASE_URL=sqlite:///inventory.db
# For MySQL: mysql+pymysql://user:password@localhost/dbname

# Default admin credentials (used only on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
ADMIN_EMAIL=admin@example.com

# Email (Gmail example — use an App Password, not your login password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password

# WhatsApp & SMS via Twilio
# Sign up at https://www.twilio.com — free trial available
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# WhatsApp sandbox number (use +14155238886 for Twilio sandbox)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# SMS from number (must be a Twilio-purchased number)
TWILIO_SMS_FROM=+1xxxxxxxxxx

# High-value asset alert threshold in ₹ (default: 50000)
HIGH_VALUE_THRESHOLD=50000
